# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
DB_HOST=db
DB_PORT=5432
DB_NAME=mazaad
DB_USER=postgres
DB_PASSWORD=postgres
DB_URL=jdbc:postgresql://${DB_HOST}:${DB_PORT}/${DB_NAME}

# -----------------------------------------------------------------------------
# AWS Configuration
# -----------------------------------------------------------------------------
AWS_ACCESS_KEY=your_aws_access_key
AWS_SECRET_KEY=your_aws_secret_key
AWS_REGION=your_aws_region
S3_BUCKET_NAME=your_s3_bucket_name

# -----------------------------------------------------------------------------
# JWT Authentication Secrets
# -----------------------------------------------------------------------------
# Generate base64-encoded strings: openssl rand -base64 64
JWT_SECRET_KEY=your_base64_encoded_jwt_secret_key
JWT_REFRESH_SECRET_KEY=your_base64_encoded_jwt_refresh_secret_key

# -----------------------------------------------------------------------------
# WhatsApp API Configuration
# -----------------------------------------------------------------------------
WHATSAPP_API_KEY=your_whatsapp_api_key
WHATSAPP_SOURCE_NAME=mazaad
WHATSAPP_SOURCE_NUMBER=xxxxxxxxxxxx
WHATSAPP_TEMPLATE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx